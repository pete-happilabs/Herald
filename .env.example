NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://herald:herald@postgres:5432/herald
REDIS_URL=redis://redis:6379

# Fast2SMS DLT Configuration
FAST2SMS_API_KEY=your_fast2sms_api_key
FAST2SMS_ENTITY_ID=your_entity_id
FAST2SMS_SENDER_ID=YOURID

# BulkSMS Configuration (Fallback)
BULKSMS_API_KEY=your_bulksms_api_key
BULKSMS_API_URL=https://www.bulksmsplans.com/api/send_sms
BULKSMS_SENDER_ID=YOURID
BULKSMS_ENTITY_ID=your_entity_id
BULKSMS_OTP_TEMPLATE_ID=your_template_id

# AWS SES Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
SES_FROM_EMAIL=noreply@yourdomain.com

# Gmail Configuration
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# Herald API Authentication
API_KEY=your_api_key_here

# DLT Service Configuration
DLT_PORT=3002
DLT_AUTO_RETRY_ENABLED=true
DLT_AUTO_RETRY_INTERVAL=15
DLT_ARCHIVE_AGE_HOURS=168
DLT_ARCHIVE_CLEANUP_DAYS=90
